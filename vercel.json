{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": "wanderlust_main",
  "builds": [
    {
      "src": "api/delete-cloudinary.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/delete-cloudinary", "dest": "/api/delete-cloudinary.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}