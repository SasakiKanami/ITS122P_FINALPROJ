{
  "version": 2,
  "builds": [
    {
      "src": "build.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["wanderlust_main/js/firebase-config-template.js"]
      }
    },
    {
      "src": "api/delete-cloudinary.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/delete-cloudinary", "dest": "/api/delete-cloudinary.js" }
  ]
}